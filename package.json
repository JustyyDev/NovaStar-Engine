{
  "name": "novastar-engine",
  "version": "0.1.2",
  "description": "NovaStar Engine — A cartoony low-poly 3D game engine with custom scripting language and visual editor",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron electron/main.cjs --dev\"",
    "electron:build": "vite build && electron-builder --config electron-builder.json",
    "electron:build:win": "vite build && electron-builder --config electron-builder.json --win",
    "electron:build:mac": "vite build && electron-builder --config electron-builder.json --mac",
    "electron:build:linux": "vite build && electron-builder --config electron-builder.json --linux",
    "electron:build:all": "vite build && electron-builder --config electron-builder.json --win --mac --linux",

    "icons": "node scripts/generate-ico.cjs",
    "postinstall": "node scripts/generate-ico.cjs",
    "clean": "rm -rf dist release node_modules/.vite"
  },
  "dependencies": {
    "three": "^0.162.0"
  },
  "devDependencies": {
    "vite": "^5.4.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0"
  },
  "author": "",
  "license": "MIT"
}
