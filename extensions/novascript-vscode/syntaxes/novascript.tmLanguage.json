{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "NovaScript",
  "scopeName": "source.novascript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#engine-api" },
    { "include": "#entity-declaration" },
    { "include": "#function-declaration" },
    { "include": "#function-call" },
    { "include": "#variable-declaration" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.novascript",
          "match": "//.*$"
        },
        {
          "name": "comment.block.novascript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.novascript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.novascript",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.novascript",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.novascript",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.novascript",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.hex.novascript",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.integer.novascript",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.novascript",
          "match": "\\b(if|else|while|for|foreach|in|return|break|continue|switch|case|default|try|catch|throw|finally|async|await|yield)\\b"
        },
        {
          "name": "keyword.declaration.novascript",
          "match": "\\b(entity|component|class|extends|interface|enum|type)\\b"
        },
        {
          "name": "keyword.other.novascript",
          "match": "\\b(import|from|export|as|new|spawn|destroy|emit|print|scene)\\b"
        },
        {
          "name": "storage.modifier.novascript",
          "match": "\\b(var|let|const|static|public|private|protected|readonly|override|abstract|virtual)\\b"
        },
        {
          "name": "storage.type.function.novascript",
          "match": "\\b(fn)\\b"
        },
        {
          "name": "variable.language.this.novascript",
          "match": "\\b(this|super|self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.novascript",
          "match": "\\b(int|float|double|string|bool|void|any)\\b"
        },
        {
          "name": "support.type.engine.novascript",
          "match": "\\b(vec2|vec3|vec4|color|rect|transform|array|map)\\b"
        },
        {
          "name": "support.type.game.novascript",
          "match": "\\b(Entity|Component|Sprite|Tilemap|Mesh|Material|Light|Camera|Collider|RigidBody)\\b"
        }
      ]
    },
    "engine-api": {
      "patterns": [
        {
          "name": "support.class.engine.novascript",
          "match": "\\b(Input|Audio|Particles|Scene|Camera|UI|Anim|Timer|Save|Events|Assets|Sprite|Tilemap|Mode2D|Build|Engine|Math)\\b"
        },
        {
          "name": "support.function.lifecycle.novascript",
          "match": "\\b(onReady|onUpdate|onFixedUpdate|onDraw|onCollision|onTriggerEnter|onTriggerExit|onDestroy|onLand)\\b"
        },
        {
          "name": "support.function.builtin.novascript",
          "match": "\\b(print|random|randomRange|randomInt|abs|floor|ceil|round|min|max|clamp|lerp|inverseLerp|remap|sin|cos|tan|atan2|sqrt|pow|sign|toRadians|toDegrees|distance|distance3D|smoothstep|pingpong|range|shuffle|pick|toString|toNumber|toInt|toFloat|vec2|vec3|color|hex|time|deltaTime|fps)\\b"
        }
      ]
    },
    "entity-declaration": {
      "patterns": [
        {
          "match": "\\b(entity)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.novascript" },
            "2": { "name": "entity.name.type.class.novascript" }
          }
        },
        {
          "match": "\\b(class)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.novascript" },
            "2": { "name": "entity.name.type.class.novascript" }
          }
        },
        {
          "match": "\\b(extends)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.novascript" },
            "2": { "name": "entity.other.inherited-class.novascript" }
          }
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "storage.type.function.novascript" },
            "2": { "name": "entity.name.function.novascript" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.novascript" }
          }
        }
      ]
    },
    "variable-declaration": {
      "patterns": [
        {
          "match": "\\b(var|let|const)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.novascript" },
            "2": { "name": "variable.other.novascript" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.novascript",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.novascript",
          "match": "\\b(null)\\b"
        },
        {
          "name": "constant.language.math.novascript",
          "match": "\\b(PI|TAU|DEG2RAD|RAD2DEG|Infinity)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.novascript",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.compound.novascript",
          "match": "(\\+=|-=|\\*=|/=)"
        },
        {
          "name": "keyword.operator.assignment.novascript",
          "match": "(=)"
        },
        {
          "name": "keyword.operator.logical.novascript",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.novascript",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.increment.novascript",
          "match": "(\\+\\+|--)"
        },
        {
          "name": "keyword.operator.arrow.novascript",
          "match": "(=>)"
        },
        {
          "name": "keyword.operator.accessor.novascript",
          "match": "\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.novascript",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.parameters.novascript",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.array.novascript",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.separator.comma.novascript",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.novascript",
          "match": ";"
        },
        {
          "name": "punctuation.separator.colon.novascript",
          "match": ":"
        }
      ]
    }
  }
}
